APP_NAME=AI Crypto Trading Assistant
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
DATABASE_URL=sqlite:///./dev_trading.db
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN_REGEX=^http://(localhost|127\.0\.0\.1|10\.\d+\.\d+\.\d+|192\.168\.\d+\.\d+|172\.(1[6-9]|2\d|3[0-1])\.\d+\.\d+):5173$

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
AUTH_SECRET_KEY=change-this-long-random-secret

DEFAULT_MODE=DEMO
DEFAULT_CONTROL_MODE=MANUAL
BOT_INTERVAL_SECONDS=60
AUTO_START_SCHEDULER=false

BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_SECRET=
BINANCE_TESTNET_KEY_TYPE=hmac
BINANCE_TESTNET_PRIVATE_KEY_PATH=
BINANCE_TESTNET_PRIVATE_KEY=
BINANCE_REAL_API_KEY=
BINANCE_REAL_SECRET=
BINANCE_REAL_KEY_TYPE=hmac
BINANCE_REAL_PRIVATE_KEY_PATH=
BINANCE_REAL_PRIVATE_KEY=

OPENROUTER_API_KEY=
NVIDIA_API_KEY=
AI_PROVIDER=openrouter
AI_ENABLED=false
AI_MODEL=qwen/qwen3-235b-a22b:free
AI_FALLBACK_MODEL=google/gemini-2.5-flash-lite
AI_MAX_CALLS_PER_DAY=200
AI_MAX_INPUT_TOKENS=6000
AI_MAX_OUTPUT_TOKENS=800
AI_TEMPERATURE=0.1
AI_QUEUE_WAIT_SECONDS=180
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b

MARKET_INTEL_ENABLE_COINGECKO=true
MARKET_INTEL_RSS_URLS=
MARKET_DATA_PROVIDER=kraken_public

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

LOG_LEVEL=INFO

# Optional PostgreSQL URL for a future server deployment:
# DATABASE_URL=postgresql+psycopg://trading:trading@localhost:5432/trading
